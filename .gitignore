# Rejected painterly art set (archived; superseded by the cartoon set).
public/assets/skin/cards/art_v1_painterly/
# Frame backup created by scripts/frames-install.js (pure rollback safety net).
public/assets/skin/frames/v1_backup/
# Mobile-UI test harness OUTPUTS (breaker screenshots + result JSONLs). The
# harness CODE (harness/*.js) is tracked; its run artifacts are not.
harness/results/
# Scratch temp dir from animation capture work.
.tmp-dice-anim/
